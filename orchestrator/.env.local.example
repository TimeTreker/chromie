# Host-side orchestrator settings
ASR_URL=ws://localhost:9001
TTS_URL=ws://localhost:5000
LLM_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=gemma4:e2b

# Choose real devices from `python list_devices.py`.
# Avoid generic wrappers like default/sysdefault/pipewire/monitor if possible.
INPUT_DEVICE_INDEX=
OUTPUT_DEVICE_INDEX=
INPUT_DEVICE_NAME=
OUTPUT_DEVICE_NAME=

# Speaker profile. Use `default` if you copied your profile to tts/speakers/default.json.
TTS_SPEAKER_ID=default

# TTS source PCM rate. This is NOT the speaker rate.
# The orchestrator auto-resamples from this source rate to the detected output device rate.
TTS_SAMPLE_RATE=44100
TTS_FLUSH_CHARS=160

# VAD / anti-false-trigger tuning
ORCH_VAD_MODE=3
ORCH_MIN_RMS=120
ORCH_BARGE_IN_MIN_RMS=350
ORCH_MIN_AUDIO_MS=1200
ORCH_VAD_SILENCE_MS=650

# Playback and retry
ORCH_PLAYBACK_CHUNK_MS=80
ORCH_TTS_WS_RETRIES=2
ORCH_TTS_WS_RETRY_DELAY_MS=300
ORCH_TTS_CONCURRENCY=1

# Ollama first-token latency tuning
OLLAMA_NUM_CTX=2048
OLLAMA_NUM_PREDICT=96
OLLAMA_TEMPERATURE=0.4
OLLAMA_TOP_P=0.9
OLLAMA_KEEP_ALIVE=30m

# Debug
ORCH_SESSION_TIMING_LOGS=true
ORCH_SAVE_AUDIO=false
RECORDINGS_DIR=../recordings
LOG_LEVEL=INFO
