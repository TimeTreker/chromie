# Copy to orchestrator/.env.local and adjust for your host.
LOG_LEVEL=INFO

# Host service endpoints. These match the application defaults and can be
# changed when services run on another host.
ASR_URL=ws://127.0.0.1:9001
TTS_URL=ws://127.0.0.1:5000
LLM_URL=http://127.0.0.1:11434/api/generate
ORCH_ENABLE_INTERACTION_RESPONSE=0
ORCH_ENABLE_SORIDORMI_SKILLS=0
ORCH_AUTO_CONFIRM_SIM_SKILLS=1
ORCH_SORIDORMI_MANIFEST=capabilities/soridormi.json
# SORIDORMI_MCP_URL=http://127.0.0.1:8000/mcp

# Speech / TTS
TTS_SPEAKER_ID=default
TTS_FLUSH_CHARS=160
ORCH_TTS_CONCURRENCY=1
ORCH_TTS_WS_RETRIES=2
ORCH_TTS_WS_RETRY_DELAY_MS=300
ORCH_VOICE_SYSTEM_PROMPT=You are a real-time voice assistant. Answer briefly in 1 to 3 short sentences. Do not use markdown.

# Audio / VAD
ORCH_INPUT_DEVICE=
ORCH_OUTPUT_DEVICE=
ORCH_INPUT_RATE=48000
ORCH_OUTPUT_RATE=48000
ORCH_INPUT_CHANNELS=1
ORCH_OUTPUT_CHANNELS=2
ORCH_INPUT_BLOCK_MS=30
ORCH_OUTPUT_BLOCK_MS=30
ORCH_INPUT_LATENCY=low
ORCH_OUTPUT_LATENCY=low
ORCH_VAD_MODE=3
ORCH_VAD_SILENCE_MS=650
ORCH_MIN_AUDIO_MS=1200
ORCH_MIN_RMS=120
ORCH_BARGE_IN_MIN_RMS=350
ORCH_PLAYBACK_CHUNK_MS=80

# Debugging
ORCH_SESSION_TIMING_LOGS=true
# ORCH_EVENT_LOG_PATH=.chromie/acceptance/manual-events.jsonl
ORCH_SAVE_AUDIO=false
RECORDINGS_DIR=recordings
