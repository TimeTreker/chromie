# Chromie RTX 4090 Laptop GPU example environment
COMPOSE_PROJECT_NAME=chromie

# Optional proxy for container model downloads.
# Leave blank if you do not use a local proxy.
# For a host-side proxy such as Clash/V2Ray, use http://host.docker.internal:7897
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,host.docker.internal,chromie-asr,chromie-tts,chromie-llm,asr,tts,llm

# CUDA images. RTX 4090 Laptop GPU is Ada Lovelace: CUDA architecture 8.9.
# CUDA 12.8 keeps this package close to the original 5090 package while remaining valid for 4090.
ASR_CUDA_IMAGE=nvidia/cuda:12.8.1-cudnn-runtime-ubuntu24.04
TTS_CUDA_IMAGE=nvidia/cuda:12.8.1-devel-ubuntu24.04
TTS_CUDA_ARCH=89
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility

# Hugging Face cache/offline mode.
HF_HUB_OFFLINE=0
TRANSFORMERS_OFFLINE=0

# ASR
ASR_MODEL=dropbox-dash/faster-whisper-large-v3-turbo
ASR_DEVICE=cuda
ASR_COMPUTE_TYPE=float16
ASR_LANGUAGE=
ASR_BEAM_SIZE=1
ASR_VAD_FILTER=false
ASR_CONDITION_ON_PREVIOUS_TEXT=false

# TTS / OuteTTS / llama.cpp
TTS_MODEL_SIZE=0.6B
TTS_QUANTIZATION=FP16
TTS_N_GPU_LAYERS=-1
TTS_CONTEXT_SIZE=4096
TTS_MAX_LENGTH=4096
TTS_N_BATCH=192
TTS_THREADS=4
TTS_SAMPLE_RATE=44100
TTS_CHUNK_MS=120
TTS_MAX_CONCURRENT_SYNTHESIS=1
TTS_TEMPERATURE=0.4
TTS_REPETITION_PENALTY=1.1
TTS_MIN_TEXT_CHARS=4
TTS_MAX_TEXT_CHARS=220
TTS_GENERATION_RETRIES=1
TTS_RESET_LLAMA_STATE=1
TTS_AUDIO_CODEC_DEVICE=cpu
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# Ollama
OLLAMA_MODEL=gemma4:e2b
OLLAMA_KEEP_ALIVE=30m
OLLAMA_NUM_PARALLEL=1
OLLAMA_CONTEXT_LENGTH=2048
OLLAMA_NUM_CTX=2048
OLLAMA_NUM_PREDICT=96
OLLAMA_TEMPERATURE=0.4
OLLAMA_TOP_P=0.9

# Router
ROUTER_PORT=8091
ROUTER_MODE=hybrid
ROUTER_RULES_FIRST=1
ROUTER_USE_LLM=0
ROUTER_MODEL=qwen3:0.6b
ROUTER_OLLAMA_URL=http://chromie-llm:11434
ROUTER_MAX_CONTEXT_CHARS=1200
ROUTER_TIMEOUT_MS=2000
ROUTER_LOG_LEVEL=INFO


# Agent
AGENT_PORT=8092
AGENT_OLLAMA_URL=http://chromie-llm:11434
AGENT_USE_LLM=1
AGENT_MODEL=gemma4:26b
AGENT_TIMEOUT_MS=120000
AGENT_ENABLE_HARDWARE_CLIENT=0
AGENT_LOG_LEVEL=INFO


# Optional host hardware daemon
HARDWARE_DAEMON_URL=http://host.docker.internal:8095

