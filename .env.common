# Chromie common environment
# Hardware-specific values are in env/profiles/*.env.
# User-local overrides go in .env.local.
# Generated runtime environment goes to .env.runtime.

COMPOSE_PROJECT_NAME=chromie

# Proxy handling. By default Chromie clears host proxy variables before Docker/curl
# commands because local container/service traffic must not be routed through a proxy.
# Set CHROMIE_KEEP_PROXY=1 in .env.local only if your network requires a proxy for
# package/model downloads during build.
CHROMIE_KEEP_PROXY=0
CHROMIE_NO_PROXY=localhost,127.0.0.1,::1,host.docker.internal,chromie-asr,chromie-tts,chromie-llm,chromie-router,chromie-agent
HTTP_PROXY=
HTTPS_PROXY=
FTP_PROXY=
ALL_PROXY=
http_proxy=
https_proxy=
ftp_proxy=
all_proxy=
NO_PROXY=localhost,127.0.0.1,::1,host.docker.internal,chromie-asr,chromie-tts,chromie-llm,chromie-router,chromie-agent
no_proxy=localhost,127.0.0.1,::1,host.docker.internal,chromie-asr,chromie-tts,chromie-llm,chromie-router,chromie-agent

# Common container/GPU visibility defaults.
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility

# Hugging Face cache/offline mode.
HF_HUB_OFFLINE=0
TRANSFORMERS_OFFLINE=0

# Router: keep rule-based by default. This is fast and works well for voice.
ROUTER_USE_LLM=0
ROUTER_MODEL=qwen3:0.6b
ROUTER_TIMEOUT_MS=1500

# Agent: the real talking brain.
AGENT_USE_LLM=1
AGENT_MAX_SPEAK_CHARS=160
AGENT_ENABLE_HARDWARE_CLIENT=0
HARDWARE_DAEMON_URL=http://host.docker.internal:8095

# Ollama common behavior.
OLLAMA_KEEP_ALIVE=24h
OLLAMA_LOAD_TIMEOUT=10m
OLLAMA_NUM_PARALLEL=1
OLLAMA_WARM_TIMEOUT_SECONDS=600
OLLAMA_WARM_REQUEST_TIMEOUT_SECONDS=300
WARM_OLLAMA_BEFORE_ORCH=1

# TTS stability defaults.
TTS_MAX_CONCURRENT_SYNTHESIS=1
TTS_GENERATION_RETRIES=1
TTS_RESET_LLAMA_STATE=1
TTS_AUDIO_CODEC_DEVICE=cpu
TTS_TEMPERATURE=0.4
TTS_REPETITION_PENALTY=1.1
TTS_MIN_TEXT_CHARS=4
TTS_MAX_TEXT_CHARS=220
TTS_SAMPLE_RATE=44100
TTS_CHUNK_MS=120

# OuteTTS generation budget guard.
# IMPORTANT: TTS_MAX_LENGTH is NOT a text character limit. It is the OuteTTS / llama
# generation token budget. Setting it too low, such as 100/120/180, can make OuteTTS
# emit zero audio codec tokens and fail with "torch.cat(): expected a non-empty list".
# Use TTS_MAX_TEXT_CHARS to make spoken replies shorter.
MIN_TTS_GENERATION_LENGTH=1024

# Orchestrator behavior.
ORCH_TTS_DEDUPE_WINDOW_SEC=3.0
ORCH_SAVE_AUDIO=false

# Logging.
LOG_LEVEL=INFO

# Default CUDA images for desktop NVIDIA builds.
# Jetson/ARM64 container images may need a later docker-compose.jetson.yml and Jetson-specific Dockerfiles.
ASR_CUDA_IMAGE=nvidia/cuda:12.8.1-cudnn-runtime-ubuntu24.04
TTS_CUDA_IMAGE=nvidia/cuda:12.8.1-devel-ubuntu24.04

# ASR defaults; hardware profiles override model/compute type.
ASR_DEVICE=cuda
ASR_LANGUAGE=
ASR_BEAM_SIZE=1
ASR_VAD_FILTER=false
ASR_CONDITION_ON_PREVIOUS_TEXT=false

# TTS defaults; hardware profiles override size/context/batch/thread values.
TTS_QUANTIZATION=FP16
TTS_N_GPU_LAYERS=-1
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
