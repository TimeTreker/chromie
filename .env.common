# Chromie common environment
# Hardware-specific values are in env/profiles/*.env.
# User-local overrides go in .env.local.
# Generated runtime environment goes to .env.runtime.

COMPOSE_PROJECT_NAME=chromie

# Optional proxy for container model downloads. Leave blank if unused.
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,host.docker.internal,chromie-asr,chromie-tts,chromie-llm,chromie-router,chromie-agent

# Common container/GPU visibility defaults.
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility

# Hugging Face cache/offline mode.
HF_HUB_OFFLINE=0
TRANSFORMERS_OFFLINE=0

# Router: keep rule-based by default. This is fast and works well for voice.
ROUTER_USE_LLM=0
ROUTER_MODEL=qwen3:0.6b
ROUTER_TIMEOUT_MS=1500

# Agent: the real talking brain.
AGENT_USE_LLM=1
AGENT_MAX_SPEAK_CHARS=160
AGENT_ENABLE_TASK_GRAPH_PLANNING=0
AGENT_ENABLE_READ_ONLY_TASK_GRAPH_EXECUTION=0
AGENT_ENABLE_PLANNING_TASK_GRAPH_EXECUTION=0
AGENT_ENABLE_GUARDED_TASK_GRAPH_EXECUTION=0
AGENT_ENABLE_PHYSICAL_TASK_GRAPH_EXECUTION=0
AGENT_TASK_GRAPH_EXECUTION_TOKEN=
# Comma-separated files/directories inside the Agent container.
AGENT_CAPABILITY_MANIFESTS=
AGENT_ENABLE_HARDWARE_CLIENT=0
HARDWARE_DAEMON_URL=http://host.docker.internal:8095

# Short-term conversation state.
# SID is still one VAD utterance. conversation_id spans multiple turns.
ORCH_ENABLE_CONVERSATION_STATE=1
ORCH_CONVERSATION_ID=local_default
ORCH_CONVERSATION_MAX_TURNS=12
ORCH_CONVERSATION_IDLE_TIMEOUT_SEC=180
ORCH_CONVERSATION_HARD_IDLE_TIMEOUT_SEC=900
ORCH_CONVERSATION_TURN_MAX_TEXT_CHARS=260
ORCH_CONVERSATION_MAX_CONTEXT_CHARS=2200
ORCH_CONVERSATION_MAX_PENDING_TASKS=8
# Optional phrase overrides use | as separator.
# ORCH_CONVERSATION_RESET_PHRASES=new topic|start over|换个话题|重新开始
# ORCH_CONVERSATION_FOLLOWUP_PHRASES=when|answer|result|what about|刚才|结果|什么时候

# Ollama common behavior.
OLLAMA_KEEP_ALIVE=24h
OLLAMA_LOAD_TIMEOUT=10m
OLLAMA_NUM_PARALLEL=1
OLLAMA_WARM_TIMEOUT_SECONDS=600
OLLAMA_WARM_REQUEST_TIMEOUT_SECONDS=300
WARM_OLLAMA_BEFORE_ORCH=1

# TTS stability defaults.
TTS_MAX_CONCURRENT_SYNTHESIS=1
TTS_GENERATION_RETRIES=1
TTS_RESET_LLAMA_STATE=1
TTS_AUDIO_CODEC_DEVICE=cpu
TTS_TEMPERATURE=0.4
TTS_REPETITION_PENALTY=1.1
TTS_MIN_TEXT_CHARS=4
TTS_MAX_TEXT_CHARS=220
TTS_SAMPLE_RATE=44100
TTS_CHUNK_MS=120

# Orchestrator behavior.
ORCH_ENABLE_ROUTER=1
ORCH_ENABLE_AGENT=1
ROUTER_URL=http://127.0.0.1:8091
AGENT_URL=http://127.0.0.1:8092
ACTION_EXECUTOR_URL=http://127.0.0.1:8095
ORCH_ROUTER_TIMEOUT_MS=900
ORCH_ACTION_TIMEOUT_MS=5000
ORCH_ACTION_DRY_RUN=true
ORCH_TTS_DEDUPE_WINDOW_SEC=3.0
ORCH_SAVE_AUDIO=false

# Logging.
LOG_LEVEL=INFO

# Default CUDA images for desktop NVIDIA builds.
# Jetson/ARM64 container images may need a later docker-compose.jetson.yml and Jetson-specific Dockerfiles.
ASR_CUDA_IMAGE=nvidia/cuda:12.8.1-cudnn-runtime-ubuntu24.04
TTS_CUDA_IMAGE=nvidia/cuda:12.8.1-devel-ubuntu24.04

# ASR defaults; hardware profiles override model/compute type.
ASR_DEVICE=cuda
ASR_LANGUAGE=
ASR_BEAM_SIZE=1
ASR_VAD_FILTER=false
ASR_CONDITION_ON_PREVIOUS_TEXT=false

# TTS defaults; hardware profiles override size/context/batch/thread values.
TTS_QUANTIZATION=FP16
TTS_N_GPU_LAYERS=-1
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
