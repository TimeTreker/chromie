# Reproducible build and runtime source references. Publishable release bundles
# additionally record resolved image and Ollama model digests.
CHROMIE_IMAGE_TAG=latest
PYTHON_IMAGE=python:3.12.10-slim-bookworm
OLLAMA_IMAGE=ollama/ollama:latest

# Chromie common environment
# Hardware-specific values are in env/profiles/*.env.
# User-local overrides go in .env.local.
# Generated runtime environment goes to .env.runtime.

COMPOSE_PROJECT_NAME=chromie

# Optional proxy for container model downloads. Leave blank if unused.
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,host.docker.internal,chromie-asr,chromie-tts,chromie-llm,chromie-router,chromie-agent

# Common container/GPU visibility defaults.
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility

# Hugging Face cache/offline mode.
HF_HUB_OFFLINE=0
TRANSFORMERS_OFFLINE=0

# ASR backend defaults. Current supported mode is final utterance only.
ASR_BACKEND=sherpa_onnx
ASR_MODE=final

# Default sherpa-onnx ASR backend. Faster-Whisper remains installed/selectable.
SHERPA_ONNX_MODEL_TYPE=sense_voice
SHERPA_ONNX_PROVIDER=cuda
SHERPA_ONNX_NUM_THREADS=2
SHERPA_ONNX_LANGUAGE=auto
SHERPA_ONNX_USE_ITN=true
SHERPA_ONNX_DEBUG=false
SHERPA_ONNX_MODEL_FILE=
SHERPA_ONNX_TOKENS_FILE=

# Router: use a small fast model for semantic routing; safety interrupts remain deterministic.
ROUTER_USE_LLM=1
ROUTER_MODEL=qwen3:4b
ROUTER_REVIEW_MODEL=gemma4:e2b
# Shared capability catalog served by the Agent service.
ROUTER_CAPABILITY_CATALOG_URL=http://chromie-agent:8092
ROUTER_CAPABILITY_CATALOG_TIMEOUT_MS=400
ROUTER_CAPABILITY_CATALOG_CACHE_TTL_MS=5000
ROUTER_CAPABILITY_MATCH_LIMIT=8
ROUTER_POST_INTERRUPT_REVIEW_ENABLED=0
ROUTER_SLOW_REVIEW_RECOVERY_ENABLED=1
# Keep legacy phrase-based robot routing disabled; catalog routing is authoritative.
ROUTER_ALLOW_LEGACY_ROBOT_RULES=0

# Immutable default TTS model snapshots. Change these together with
# release/model-lock.json and release documentation.
TTS_TOKENIZER_REPO=OuteAI/OuteTTS-1.0-0.6B
TTS_TOKENIZER_REVISION=e7bcd87b0ca47fd8c46317c8f745a5e4e19c7b5c
TTS_GGUF_REPO=OuteAI/OuteTTS-1.0-0.6B-GGUF
TTS_GGUF_REVISION=d85d0f1e5242c3fb04c95f55bd99ec3ebd4c2d16
ROUTER_TIMEOUT_MS=5400
ROUTER_LLM_TIMEOUT_MS=5400
ROUTER_LLM_NUM_CTX=4096
ROUTER_LLM_NUM_PREDICT=96
ROUTER_LLM_KEEP_ALIVE=24h
ROUTER_WARM_LLM_ON_STARTUP=1
ROUTER_WARM_LLM_TIMEOUT_MS=60000
ROUTER_REVIEW_TIMEOUT_MS=2500
ROUTER_GENERIC_CHAT_REVIEW_ENABLED=1
ROUTER_TOOL_FAST_SPEECH_REPAIR_ENABLED=0

# Agent: the real talking brain.
AGENT_USE_LLM=1
AGENT_RESPONSE_REVIEW_ENABLED=0
AGENT_RESPONSE_REVIEW_MODEL=gemma4:e2b
AGENT_RESPONSE_REVIEW_TIMEOUT_MS=4000
AGENT_RESPONSE_REVIEW_MODE=auto
AGENT_MAX_SPEAK_CHARS=140
AGENT_CONVERSATION_NUM_CTX=2048
AGENT_CONVERSATION_NUM_PREDICT=64
AGENT_DEEPTHINKING_NUM_CTX=8192
AGENT_DEEPTHINKING_NUM_PREDICT=384
AGENT_INTERACTION_OUTPUT_MODE=native
AGENT_NATIVE_INTERACTION_FALLBACK=0
AGENT_LEGACY_CAPABILITY_FALLBACK_ENABLED=0
AGENT_ENABLE_TASK_GRAPH_PLANNING=0
AGENT_ENABLE_READ_ONLY_TASK_GRAPH_EXECUTION=0
AGENT_ENABLE_PLANNING_TASK_GRAPH_EXECUTION=0
AGENT_ENABLE_PARALLEL_TASK_GRAPH_EXECUTION=0
AGENT_TASK_GRAPH_MAX_CONCURRENCY=4
AGENT_ENABLE_GUARDED_TASK_GRAPH_EXECUTION=0
AGENT_ENABLE_PHYSICAL_TASK_GRAPH_EXECUTION=0
AGENT_EXPRESSIVE_BODY_CUES=off
AGENT_SOCIAL_ATTENTION_MODE=off
AGENT_SOCIAL_ATTENTION_MODEL=qwen3:4b
AGENT_SOCIAL_ATTENTION_TIMEOUT_MS=2500
AGENT_SOCIAL_ATTENTION_NUM_CTX=4096
AGENT_SOCIAL_ATTENTION_NUM_PREDICT=160
AGENT_SOCIAL_ATTENTION_WAIT_AFTER_RESPONSE_MS=0
AGENT_SOCIAL_ATTENTION_MAX_BEHAVIORS=2
AGENT_SOCIAL_ATTENTION_CAPABILITIES=soridormi.express_attention,soridormi.look_at_person,soridormi.blink_eyes
AGENT_SOCIAL_ATTENTION_FALLBACK_TARGET=none
AGENT_SOCIAL_ATTENTION_FALLBACK_DIRECTION=
AGENT_SOCIAL_ATTENTION_FALLBACK_YAW_RAD=
AGENT_SOCIAL_ATTENTION_FALLBACK_CONFIDENCE=0.0
AGENT_REQUIRE_CAPABILITY_PLAN_REVIEW=0
AGENT_TASK_GRAPH_EXECUTION_TOKEN=
AGENT_TASK_GRAPH_DIAGNOSTICS_TOKEN=
AGENT_TASK_GRAPH_TRACE_MAX_ENTRIES=128
AGENT_TASK_GRAPH_TRACE_TTL_SEC=900
AGENT_TASK_GRAPH_GRANT_MAX_ENTRIES=128
# Comma-separated files/directories. Docker Compose supplies the Agent
# container's mounted Soridormi manifest by default; host-side imports keep this
# empty unless a caller explicitly opts in.
AGENT_CAPABILITY_MANIFESTS=
SORIDORMI_MCP_URL=
AGENT_CAPABILITY_CATALOG_REFRESH_SEC=30
AGENT_CAPABILITY_MATCH_MIN_SCORE=0.16
AGENT_CAPABILITY_MATCH_LIMIT=8
AGENT_CAPABILITY_PROMPT_TIER_PRESET=capabilities/prompt_tiers.json
AGENT_CAPABILITY_PROMPT_TIER_OVERRIDES=
AGENT_CAPABILITY_NUM_CTX=24576
AGENT_CAPABILITY_NUM_PREDICT=512
AGENT_CAPABILITY_REVIEW_NUM_PREDICT=160
AGENT_GOAL_ASSOCIATION_ENABLED=1
AGENT_GOAL_ASSOCIATION_MODEL=qwen3:4b
AGENT_GOAL_ASSOCIATION_TIMEOUT_MS=3000
AGENT_GOAL_ASSOCIATION_MIN_CONFIDENCE=0.65
AGENT_GOAL_ASSOCIATION_MAX_ACTIVE_GOALS=8
AGENT_GOAL_ASSOCIATION_NUM_CTX=4096
AGENT_GOAL_ASSOCIATION_NUM_PREDICT=512
AGENT_FAST_PLANNER_ENABLED=1
AGENT_FAST_PLANNER_MODEL=qwen3:4b
AGENT_FAST_PLANNER_TIMEOUT_MS=2500
AGENT_FAST_PLANNER_MIN_CONFIDENCE=0.80
AGENT_FAST_PLANNER_NUM_CTX=4096
AGENT_FAST_PLANNER_NUM_PREDICT=512
AGENT_FAST_PLANNER_MAX_CAPABILITIES=24
AGENT_DEEP_PLANNER_ENABLED=1
AGENT_DEEP_PLANNER_MODEL=gemma4:e2b
AGENT_DEEP_PLANNER_TIMEOUT_MS=9000
AGENT_DEEP_PLANNER_MIN_CONFIDENCE=0.65
AGENT_DEEP_PLANNER_MIN_GOAL_SATISFACTION=0.75
AGENT_DEEP_PLANNER_NUM_CTX=8192
AGENT_DEEP_PLANNER_NUM_PREDICT=1024
AGENT_DEEP_PLANNER_MAX_CAPABILITIES=96
AGENT_DEEP_PLANNER_MAX_REPLANS=1
AGENT_RESPONSE_COMPOSER_ENABLED=1
AGENT_RESPONSE_COMPOSER_MODEL=gemma4:e2b
AGENT_RESPONSE_COMPOSER_TIMEOUT_MS=4500
AGENT_RESPONSE_COMPOSER_NUM_CTX=4096
AGENT_RESPONSE_COMPOSER_NUM_PREDICT=640
AGENT_TASK_CONTINUITY_ENABLED=1
AGENT_TASK_CONTINUITY_MODEL=qwen3:4b
AGENT_TASK_CONTINUITY_TIMEOUT_MS=3000
AGENT_TASK_CONTINUITY_MIN_CONFIDENCE=0.65
AGENT_TASK_CONTINUITY_MAX_ACTIVE_TASKS=8
AGENT_TASK_CONTINUITY_NUM_CTX=4096
AGENT_TASK_CONTINUITY_NUM_PREDICT=256

# Short-term conversation state.
# SID is still one VAD utterance. conversation_id spans multiple turns.
ORCH_ENABLE_CONVERSATION_STATE=1
ORCH_CONVERSATION_ID=local_default
ORCH_CONVERSATION_MAX_TURNS=12
ORCH_CONVERSATION_IDLE_TIMEOUT_SEC=180
ORCH_CONVERSATION_HARD_IDLE_TIMEOUT_SEC=900
ORCH_CONVERSATION_TURN_MAX_TEXT_CHARS=260
ORCH_CONVERSATION_MAX_CONTEXT_CHARS=2200
ORCH_CONVERSATION_MAX_PENDING_TASKS=8
# Optional phrase overrides use | as separator.
# ORCH_CONVERSATION_RESET_PHRASES=new topic|start over|换个话题|重新开始
# ORCH_CONVERSATION_FOLLOWUP_PHRASES=when|answer|result|what about|刚才|结果|什么时候
ORCH_ENABLE_EPISODE_RECORDING=1
ORCH_EPISODE_LOG_PATH=.chromie/experience/episodes.jsonl
ORCH_EPISODE_MAX_TURNS=12

# Ollama common behavior.
OLLAMA_KEEP_ALIVE=24h
OLLAMA_LOAD_TIMEOUT=10m
OLLAMA_MAX_LOADED_MODELS=2
OLLAMA_NUM_PARALLEL=1
OLLAMA_WARM_TIMEOUT_SECONDS=600
OLLAMA_WARM_REQUEST_TIMEOUT_SECONDS=300
OLLAMA_WARM_NUM_PREDICT=1
OLLAMA_AUTO_RESTART_ON_CRASH=1
WARM_OLLAMA_BEFORE_ORCH=1

# TTS stability defaults.
TTS_MAX_CONCURRENT_SYNTHESIS=1
TTS_GENERATION_RETRIES=1
TTS_RESET_LLAMA_STATE=0
TTS_AUDIO_CODEC_DEVICE=auto
TTS_DETAILED_TIMING=1
TTS_METRICS_WINDOW=20
GGML_CUDA_DISABLE_GRAPHS=0
TTS_WORKER_STARTUP_TIMEOUT_SEC=600
TTS_TEMPERATURE=0.4
TTS_REPETITION_PENALTY=1.1
TTS_MIN_TEXT_CHARS=1
TTS_MAX_TEXT_CHARS=220
TTS_SAMPLE_RATE=44100
TTS_CHUNK_MS=120
TTS_WORKER_COUNT=1

# Orchestrator behavior.
ORCH_ENABLE_ROUTER=1
ORCH_ENABLE_AGENT=1
ORCH_ENABLE_INTERACTION_RESPONSE=0
ORCH_ENABLE_SORIDORMI_SKILLS=0
ORCH_AUTO_CONFIRM_SIM_SKILLS=1
ORCH_FAST_FIRST_RESPONSE_ENABLED=1
# Startup-primed cached acknowledgements use a hedge timer and avoid realtime TTS generation.
ORCH_FAST_FIRST_AUDIO_ENABLED=1
ORCH_FAST_FIRST_AUDIO_HEDGE_MS=750
ORCH_FAST_FIRST_AUDIO_CACHE_DIR=.chromie/cache/fast-first-audio
ORCH_FAST_FIRST_AUDIO_PRIME_ON_STARTUP=1
ORCH_FAST_FIRST_AUDIO_PRIME_TIMEOUT_MS=120000
# Legacy Router-generated tool acknowledgements still use full generative TTS and remain disabled.
ORCH_FAST_FIRST_TOOL_RESPONSE_ENABLED=0
# Dedicated semantic task continuity observes active tasks without changing them; apply remains explicit.
ORCH_GOAL_ASSOCIATION_MODE=report_only
ORCH_GOAL_ASSOCIATION_TIMEOUT_MS=3500
ORCH_FAST_PLANNER_MODE=report_only
ORCH_FAST_PLANNER_TIMEOUT_MS=3000
ORCH_DEEP_PLANNER_MODE=report_only
ORCH_DEEP_PLANNER_TIMEOUT_MS=10000
ORCH_RESPONSE_COMPOSER_MODE=report_only
ORCH_RESPONSE_COMPOSER_TIMEOUT_MS=5000
# Unified goal-driven runtime is the semantic authority for maintained chat and robot-action lanes.
# Once it starts, failures are fail-closed; the legacy CapabilityAgent planner is an explicit emergency-only path.
ORCH_COGNITIVE_RUNTIME_MODE=apply
ORCH_COGNITIVE_APPLY_LANES=chat,robot_action
ORCH_COGNITIVE_FALLBACK_POLICY=fail_closed
ORCH_LEGACY_SEMANTIC_FALLBACK_ENABLED=0
ORCH_COGNITIVE_RUNTIME_TIMEOUT_MS=25000
ORCH_COGNITIVE_HOST_REPLAN_BUDGET=1
ORCH_COGNITIVE_EVIDENCE_ENABLED=1
ORCH_COGNITIVE_EVIDENCE_INCLUDE_TEXT=0
ORCH_COGNITIVE_EVIDENCE_PATH=.chromie/evidence/cognitive-runtime/events.jsonl
ORCH_TASK_CONTINUITY_MODE=report_only
ORCH_TASK_CONTINUITY_TIMEOUT_MS=3500
ORCH_CONFIRMATION_TTL_SEC=20
ORCH_SKILL_MAX_CONCURRENCY=8
ROUTER_URL=http://127.0.0.1:8091
AGENT_URL=http://127.0.0.1:8092
ACTION_EXECUTOR_URL=http://127.0.0.1:8095
ORCH_ROUTER_TIMEOUT_MS=9000
ORCH_ASR_TIMEOUT_MS=30000
ORCH_ACTION_TIMEOUT_MS=5000
TTS_FLUSH_CHARS=80
ORCH_TTS_TEXT_CHUNKING=true
ORCH_TTS_FIRST_CHUNK_CHARS=16
ORCH_TTS_CHUNK_CHARS=120
ORCH_TTS_MIN_CHUNK_CHARS=20
ORCH_TTS_CJK_CHUNK_CHARS=36
ORCH_TTS_CJK_MIN_CHUNK_CHARS=8
ORCH_TTS_PLAYBACK_START_TIMEOUT_MS=20000
ORCH_ACTION_DRY_RUN=true
ORCH_SORIDORMI_MANIFEST=capabilities/soridormi.json
ORCH_SAVE_AUDIO=false

# Logging.
LOG_LEVEL=INFO

# Default CUDA images for desktop NVIDIA builds.
# Jetson/ARM64 container images may need a later docker-compose.jetson.yml and Jetson-specific Dockerfiles.
ASR_CUDA_IMAGE=nvidia/cuda:12.8.1-cudnn-runtime-ubuntu24.04
TTS_CUDA_IMAGE=nvidia/cuda:12.8.1-devel-ubuntu24.04

# ASR defaults; hardware profiles override model/compute type.
ASR_DEVICE=cuda
ASR_LANGUAGE=
ASR_BEAM_SIZE=1
ASR_VAD_FILTER=false
ASR_CONDITION_ON_PREVIOUS_TEXT=false
ASR_MAX_CONCURRENT_TRANSCRIPTIONS=1
ASR_STARTUP_WARMUP_ENABLED=true
ASR_STARTUP_WARMUP_AUDIO_SECONDS=1.0

# TTS defaults; hardware profiles override size/context/batch/thread values.
TTS_QUANTIZATION=FP16
TTS_N_GPU_LAYERS=-1
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# Optional structured Orchestrator event evidence (may contain private speech).
ORCH_EVENT_LOG_PATH=
