# Ignore local cache/data directories
/hf_cache/
/ollama_data/
/recordings/

# Runtime/generated hardware detection state
/.chromie/
/.env.runtime
/.env.local

# Generated Docker Compose compatibility env should not be committed.
# Note: if .env is already tracked in git, run: git rm --cached .env
/.env

# Host orchestrator local audio settings
/orchestrator/.env.local

# Python bytecode/cache and test/tool output
__pycache__/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
*.py[cod]
*$py.class

# Editor/OS noise
.DS_Store
.vscode/
.idea/
