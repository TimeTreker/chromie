# Chromie local overrides
# Copy to .env.local and edit. This file is intentionally not used directly.
# .env.local should not be committed.

# Hardware detection and the cognitive model plan are automatic.
# Do not set CHROMIE_HARDWARE_PROFILE or any profile-owned *_MODEL key here.
# Stale profile-owned entries are ignored with warnings; CHROMIE_ENV_STRICT=1
# turns those warnings into generation errors for CI/configuration cleanup.
# Update env/profiles/<detected-profile>.env when a hardware-class plan must change.

# Machine-local paths and non-profile rollout settings remain valid here.

# CosyVoice3 is the maintained default. Its built-in Git-controlled catalog is:
# TTS_VOICE_ROOT=assets/tts/voices
# TTS_DEFAULT_SPEAKER=chromie_mixed
# Override TTS_VOICE_ROOT only with another complete validated catalog.
# CHROMIE_TTS_BACKEND=oute   # explicit low-resource fallback
# CHROMIE_TTS_BACKEND=qwen3  # explicit alternative
# OLLAMA_DATA_DIR=/home/chromie/Models/ollama_data
# AGENT_RESPONSE_REVIEW_MODE=auto
# AGENT_INTERACTION_OUTPUT_MODE=legacy-adapter
# AGENT_NATIVE_INTERACTION_FALLBACK=1
# Emergency-only semantic rollback; enable both host and Agent gates deliberately.
# ORCH_LEGACY_SEMANTIC_FALLBACK_ENABLED=1
# AGENT_LEGACY_CAPABILITY_FALLBACK_ENABLED=1
# ROUTER_USE_LLM=0
# Shared capability catalog: Router queries the Agent catalog, while native
# InteractionRuntime rechecks the same in-process catalog before responding.
# ROUTER_CAPABILITY_CATALOG_URL=http://chromie-agent:8092
# ROUTER_CAPABILITY_CATALOG_TIMEOUT_MS=400
# ROUTER_CAPABILITY_MATCH_LIMIT=8
# ROUTER_LLM_NUM_CTX=4096
# ROUTER_LLM_NUM_PREDICT=192
# ROUTER_REVIEW_TIMEOUT_MS=2500
# ROUTER_GENERIC_CHAT_REVIEW_ENABLED=1
# ROUTER_TOOL_FAST_SPEECH_REPAIR_ENABLED=0
# ROUTER_POST_INTERRUPT_REVIEW_ENABLED=0
# ROUTER_SLOW_REVIEW_RECOVERY_ENABLED=0
# ROUTER_ALLOW_LEGACY_ROBOT_RULES=0
# AGENT_CAPABILITY_CATALOG_REFRESH_SEC=30
# AGENT_CAPABILITY_MATCH_MIN_SCORE=0.16
# AGENT_CAPABILITY_MATCH_LIMIT=8
# AGENT_EXPRESSIVE_BODY_CUES=off
# AGENT_REQUIRE_CAPABILITY_PLAN_REVIEW=0
# AGENT_CAPABILITY_NUM_CTX=24576
# AGENT_CAPABILITY_NUM_PREDICT=512
# AGENT_CAPABILITY_REVIEW_NUM_PREDICT=160
# AGENT_GOAL_ASSOCIATION_ENABLED=1
# AGENT_GOAL_ASSOCIATION_TIMEOUT_MS=3000
# AGENT_GOAL_ASSOCIATION_MIN_CONFIDENCE=0.65
# AGENT_GOAL_ASSOCIATION_MAX_ACTIVE_GOALS=8
# AGENT_GOAL_ASSOCIATION_NUM_CTX=4096
# AGENT_GOAL_ASSOCIATION_NUM_PREDICT=512
# AGENT_FAST_PLANNER_ENABLED=1
# AGENT_FAST_PLANNER_TIMEOUT_MS=2500
# AGENT_FAST_PLANNER_MIN_CONFIDENCE=0.80
# AGENT_FAST_PLANNER_NUM_CTX=4096
# AGENT_FAST_PLANNER_NUM_PREDICT=512
# AGENT_FAST_PLANNER_MAX_CAPABILITIES=24
# AGENT_DEEP_PLANNER_ENABLED=1
# AGENT_DEEP_PLANNER_TIMEOUT_MS=9000
# AGENT_DEEP_PLANNER_MIN_CONFIDENCE=0.65
# AGENT_DEEP_PLANNER_NUM_CTX=8192
# AGENT_DEEP_PLANNER_NUM_PREDICT=1024
# AGENT_DEEP_PLANNER_MAX_CAPABILITIES=96
# AGENT_DEEP_PLANNER_MAX_REPLANS=1
# AGENT_RESPONSE_COMPOSER_ENABLED=1
# AGENT_RESPONSE_COMPOSER_TIMEOUT_MS=4500
# AGENT_RESPONSE_COMPOSER_NUM_CTX=4096
# AGENT_RESPONSE_COMPOSER_NUM_PREDICT=640
# AGENT_TASK_CONTINUITY_ENABLED=1
# AGENT_TASK_CONTINUITY_TIMEOUT_MS=3000
# AGENT_TASK_CONTINUITY_MIN_CONFIDENCE=0.65
# AGENT_TASK_CONTINUITY_MAX_ACTIVE_TASKS=8
# AGENT_TASK_CONTINUITY_NUM_CTX=4096
# AGENT_TASK_CONTINUITY_NUM_PREDICT=256

# External capability manifests mounted from ./capabilities into the Agent.
# AGENT_CAPABILITY_MANIFESTS=/app/capabilities/soridormi.json
# AGENT_ENABLE_TASK_GRAPH_PLANNING=1
# AGENT_ENABLE_READ_ONLY_TASK_GRAPH_EXECUTION=1
# Stateful plan creation has its own non-physical execution gate.
# AGENT_ENABLE_PLANNING_TASK_GRAPH_EXECUTION=1
# Independent read/planning nodes may run concurrently. Default remains off.
# AGENT_ENABLE_PARALLEL_TASK_GRAPH_EXECUTION=1
# AGENT_TASK_GRAPH_MAX_CONCURRENCY=4
# Supervised side effects require both a bearer token and this enable flag.
# AGENT_ENABLE_GUARDED_TASK_GRAPH_EXECUTION=1
# AGENT_TASK_GRAPH_EXECUTION_TOKEN=replace-with-a-long-random-secret
# Physical motion has a separate opt-in.
# AGENT_ENABLE_PHYSICAL_TASK_GRAPH_EXECUTION=1

# Structured InteractionResponse rollout.
# ORCH_ENABLE_INTERACTION_RESPONSE=1
# Enable only with a reachable Soridormi MCP endpoint.
# ORCH_ENABLE_SORIDORMI_SKILLS=1
# SORIDORMI_MCP_URL=http://127.0.0.1:8000/mcp
# ORCH_SORIDORMI_MANIFEST=capabilities/soridormi.json
# Simulator launchers may opt into Soridormi-declared confirmation exemptions.
# ORCH_AUTO_CONFIRM_SIM_SKILLS=1
# Speak a truthful route-level first phrase before the slower Agent completes.
# ORCH_FAST_FIRST_RESPONSE_ENABLED=1
# ORCH_ROUTER_GENERATED_FAST_SPEECH_ENABLED=0
# ORCH_FAST_FIRST_AUDIO_ENABLED=1
# ORCH_FAST_FIRST_AUDIO_HEDGE_MS=750
# ORCH_FAST_FIRST_AUDIO_CACHE_DIR=.chromie/cache/fast-first-audio
# ORCH_FAST_FIRST_AUDIO_PRIME_ON_STARTUP=1
# ORCH_FAST_FIRST_AUDIO_PRIME_TIMEOUT_MS=120000
# Cached cues are bound to provider/speaker identity, duration-limited, and
# transcribed through ASR before use so enrollment-text leakage fails closed.
# ORCH_FAST_FIRST_AUDIO_CONTENT_GATE_ENABLED=1
# ORCH_FAST_FIRST_AUDIO_MAX_CUE_SECONDS=4
# ORCH_FAST_FIRST_AUDIO_TRANSCRIPT_MIN_SIMILARITY=0.65
# ORCH_FAST_FIRST_AUDIO_GENERATION_ATTEMPTS=2
# Optional manual invalidation salt; normally provider/speaker identity is enough.
# ORCH_FAST_FIRST_AUDIO_CACHE_REVISION=
# CosyVoice is the maintained default. Its supported shared-GPU launcher uses
# one compact Ollama model across cognitive lanes unless overridden.
# TTS_VOICE_ROOT=assets/tts/voices
# TTS_COSYVOICE_OLLAMA_MODEL=qwen3:4b
# CHROMIE_TTS_BACKEND=cosyvoice3
# Permit semantic ambient-speech ignore only while no accepted turn or active
# task keeps the interaction engaged.
# ORCH_ADDRESSEDNESS_GATE_ENABLED=1
# ORCH_ADDRESSEDNESS_ENGAGEMENT_TIMEOUT_SEC=45
# ORCH_FAST_FIRST_TOOL_RESPONSE_ENABLED=0
# Maintained single-authority runtime. Use chat,robot_action only with the
# trusted Soridormi provider enabled; the common safe base uses chat alone.
# ORCH_COGNITIVE_RUNTIME_MODE=apply
# ORCH_COGNITIVE_APPLY_LANES=chat
# ORCH_COGNITIVE_FALLBACK_POLICY=fail_closed
# ORCH_LEGACY_SEMANTIC_FALLBACK_ENABLED=0
# Standalone PR2-PR6 modes are legacy diagnostics used only when the unified
# cognitive runtime is explicitly off.
# ORCH_GOAL_ASSOCIATION_MODE=off
# ORCH_GOAL_ASSOCIATION_TIMEOUT_MS=3500
# ORCH_FAST_PLANNER_MODE=off
# ORCH_FAST_PLANNER_TIMEOUT_MS=3000
# ORCH_DEEP_PLANNER_MODE=off
# ORCH_DEEP_PLANNER_TIMEOUT_MS=10000
# ORCH_RESPONSE_COMPOSER_MODE=off
# ORCH_RESPONSE_COMPOSER_TIMEOUT_MS=5000
# ORCH_TASK_CONTINUITY_MODE=off
# ORCH_TASK_CONTINUITY_TIMEOUT_MS=3500
# ORCH_TTS_CJK_CHUNK_CHARS=36
# ORCH_TTS_CJK_MIN_CHUNK_CHARS=8
# The default provider identity is fun-cosyvoice3-0.5b. Use the launcher
# --tts-backend option for an explicit Oute or Qwen3 fallback.
# TTS_PROVIDER=fun-cosyvoice3-0.5b
# OuteTTS v3 speaker creation aligns the exact supplied transcript on CPU by
# default, rejects materially different recognized content, and rejects
# profiles whose DAC acoustic codes do not cover the reference recording.
# Select an installation-local profile only after its multilingual gate passes.
# TTS_SPEAKER_ID=chromie_mixed
# TTS_SPEAKER_ALIGNMENT_DEVICE=cpu
# TTS_SPEAKER_TRANSCRIPT_MIN_SIMILARITY=0.75
# Optional alternative-provider overrides; keep revisions immutable.
# COSYVOICE3_MODEL_REVISION=<hugging-face-commit>
# QWEN3_TTS_MODEL_REVISION=<hugging-face-commit>
# TTS_AUDIO_CODEC_DEVICE=auto
# TTS_DETAILED_TIMING=1
# TTS_METRICS_WINDOW=20
# GGML_CUDA_DISABLE_GRAPHS=0
# Spoken approvals expire and are single-use.
# ORCH_CONFIRMATION_TTL_SEC=20
# ORCH_SKILL_MAX_CONCURRENCY=8

# Conversation state overrides.
# ORCH_ENABLE_CONVERSATION_STATE=1
# ORCH_CONVERSATION_IDLE_TIMEOUT_SEC=180
# ORCH_CONVERSATION_HARD_IDLE_TIMEOUT_SEC=900
# ORCH_CONVERSATION_MAX_TURNS=12
# ORCH_CONVERSATION_MAX_CONTEXT_CHARS=2200
# ORCH_CONVERSATION_RESET_PHRASES=new topic|start over|换个话题|重新开始
# ORCH_ENABLE_EPISODE_RECORDING=1
# ORCH_EPISODE_LOG_PATH=.chromie/experience/episodes.jsonl
# ORCH_EPISODE_MAX_TURNS=12

# For conda-based host orchestrator.
CHROMIE_CONDA_ENV=Chromie

# Debugging.
# LOG_LEVEL=DEBUG
# WARM_OLLAMA_BEFORE_ORCH=0
# OLLAMA_AUTO_RESTART_ON_CRASH=1

# Proxy example, if needed.
# HTTP_PROXY=http://host.docker.internal:7897
# HTTPS_PROXY=http://host.docker.internal:7897
# NO_PROXY=localhost,127.0.0.1,host.docker.internal,chromie-asr,chromie-tts,chromie-llm,chromie-router,chromie-agent
# Optional structured Orchestrator event evidence (may contain private speech).
# ORCH_EVENT_LOG_PATH=.chromie/acceptance/manual-events.jsonl
