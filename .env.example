# Chromie example env
# Prefer the hardware profile flow:
#   ./scripts/build_runtime_env.sh
#   docker compose --env-file .env.runtime up -d
#
# Copy .env.local.example to .env.local for local overrides.

CHROMIE_HARDWARE_PROFILE=rtx5090

# Shorten spoken text with these variables.
AGENT_MAX_SPEAK_CHARS=220
AGENT_INTERACTION_OUTPUT_MODE=native
AGENT_NATIVE_INTERACTION_FALLBACK=0
TTS_MAX_TEXT_CHARS=220

# OuteTTS generation budget. Do not use this as a text-length limit.
TTS_CONTEXT_SIZE=4096
TTS_MAX_LENGTH=4096
MIN_TTS_GENERATION_LENGTH=1024

# Router LLMs. The small model performs the first-pass route choice; the review
# model only checks underspecified body-action choices before any robot skill runs.
ROUTER_MODEL=qwen3:0.6b
ROUTER_REVIEW_MODEL=gemma4:26b
AGENT_RESPONSE_REVIEW_ENABLED=1
AGENT_RESPONSE_REVIEW_MODEL=qwen3:0.6b
AGENT_RESPONSE_REVIEW_TIMEOUT_MS=4000
AGENT_EXPRESSIVE_BODY_CUES=off
AGENT_SOCIAL_ATTENTION_MODE=off
AGENT_SOCIAL_ATTENTION_MODEL=qwen3:4b
AGENT_SOCIAL_ATTENTION_TIMEOUT_MS=2500
AGENT_SOCIAL_ATTENTION_NUM_CTX=4096
AGENT_SOCIAL_ATTENTION_NUM_PREDICT=160
AGENT_SOCIAL_ATTENTION_WAIT_AFTER_RESPONSE_MS=150
AGENT_SOCIAL_ATTENTION_MAX_BEHAVIORS=2
AGENT_SOCIAL_ATTENTION_CAPABILITIES=soridormi.express_attention,soridormi.look_at_person,soridormi.blink_eyes,soridormi.nod_yes
AGENT_SOCIAL_ATTENTION_FALLBACK_TARGET=none
AGENT_SOCIAL_ATTENTION_FALLBACK_DIRECTION=
AGENT_SOCIAL_ATTENTION_FALLBACK_YAW_RAD=
AGENT_SOCIAL_ATTENTION_FALLBACK_CONFIDENCE=0.0
AGENT_REQUIRE_CAPABILITY_PLAN_REVIEW=1
AGENT_CAPABILITY_NUM_PREDICT=256
AGENT_CAPABILITY_REVIEW_NUM_PREDICT=160
AGENT_CAPABILITY_PARAMETER_REPAIR_NUM_PREDICT=384
OLLAMA_AUTO_RESTART_ON_CRASH=1
ORCH_ENABLE_EPISODE_RECORDING=1
ORCH_EPISODE_LOG_PATH=.chromie/experience/episodes.jsonl
ORCH_EPISODE_MAX_TURNS=12

# Optional structured Orchestrator event evidence (may contain private speech).
# ORCH_EVENT_LOG_PATH=.chromie/acceptance/manual-events.jsonl
