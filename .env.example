# Chromie local-override example
#
# Hardware profile selection and all profile-owned model/resource assignments
# are automatic. Never copy this file to .env; the runtime generator owns .env
# and .env.runtime. Copy selected values into .env.local only.
#
# Do not set CHROMIE_HARDWARE_PROFILE or profile-owned *_MODEL, CUDA, ASR, TTS,
# timeout, or resource keys here. Update env/profiles/<detected-profile>.env when
# a hardware-class plan must change.

# Host-local paths.
CHROMIE_CONDA_ENV=Chromie
# OLLAMA_DATA_DIR=/home/chromie/Models/ollama_data

# Maintained single-authority rollout. These values are intentionally repeated
# here so a local example cannot accidentally re-enable the legacy planner.
ORCH_COGNITIVE_RUNTIME_MODE=apply
ORCH_COGNITIVE_FALLBACK_POLICY=fail_closed
ORCH_LEGACY_SEMANTIC_FALLBACK_ENABLED=0
AGENT_LEGACY_CAPABILITY_FALLBACK_ENABLED=0

# Non-profile interaction settings.
AGENT_MAX_SPEAK_CHARS=140
AGENT_INTERACTION_OUTPUT_MODE=native
AGENT_NATIVE_INTERACTION_FALLBACK=0
ORCH_ENABLE_EPISODE_RECORDING=1
ORCH_EPISODE_LOG_PATH=.chromie/experience/episodes.jsonl
ORCH_EPISODE_MAX_TURNS=12

# Optional validation overlay. Hardware detection remains automatic.
# CHROMIE_VALIDATION_PROFILE=architecture

# Optional structured Orchestrator event evidence; may contain private speech.
# ORCH_EVENT_LOG_PATH=.chromie/acceptance/manual-events.jsonl

# Proxy example.
# HTTP_PROXY=http://host.docker.internal:7897
# HTTPS_PROXY=http://host.docker.internal:7897
# NO_PROXY=localhost,127.0.0.1,host.docker.internal,chromie-asr,chromie-tts,chromie-llm,chromie-router,chromie-agent
