# Chromie environment system
#
# Normal users should not edit this file directly.
# The runtime environment is generated from:
#
#   .env.common
#   env/profiles/<detected_hardware>.env
#   .env.local
#
# into:
#
#   .env.runtime
#
# Recommended setup:
#
#   cp .env.local.example .env.local
#   ./scripts/show_profile.sh
#   ./scripts/start_services.sh
#   ./scripts/start_orchestrator.sh
#
# To force a profile, set this in .env.local:
#
#   CHROMIE_HARDWARE_PROFILE=rtx5090
#
# See env/profiles/*.env for hardware-specific defaults.
