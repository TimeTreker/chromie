# Architecture-validation overlay.
#
# This profile prioritizes behavioral correctness and observability over latency.
# It intentionally preserves Social Attention so the complete interaction
# architecture is exercised. Infrastructure limits (timeout, truncation,
# context pressure) are reported separately from architecture attribution.

# Keep the end-to-end Agent request wider than every individual model stage.
AGENT_TIMEOUT_MS=240000
ORCH_AGENT_TIMEOUT_MS=300000

# Preserve Social Attention and allow it to execute in the simulator.
AGENT_SOCIAL_ATTENTION_MODE=sim_only
AGENT_SOCIAL_ATTENTION_TIMEOUT_MS=120000
AGENT_SOCIAL_ATTENTION_NUM_CTX=32768
AGENT_SOCIAL_ATTENTION_NUM_PREDICT=4096
AGENT_SOCIAL_ATTENTION_WAIT_AFTER_RESPONSE_MS=120000

# Goal-driven cognitive stages.
AGENT_GOAL_ASSOCIATION_TIMEOUT_MS=120000
AGENT_GOAL_ASSOCIATION_NUM_CTX=32768
AGENT_GOAL_ASSOCIATION_NUM_PREDICT=4096
AGENT_FAST_PLANNER_TIMEOUT_MS=120000
AGENT_FAST_PLANNER_NUM_CTX=32768
AGENT_FAST_PLANNER_NUM_PREDICT=4096
AGENT_DEEP_PLANNER_TIMEOUT_MS=120000
AGENT_DEEP_PLANNER_NUM_CTX=32768
AGENT_DEEP_PLANNER_NUM_PREDICT=8192
AGENT_RESPONSE_COMPOSER_TIMEOUT_MS=120000
AGENT_RESPONSE_COMPOSER_NUM_CTX=32768
AGENT_RESPONSE_COMPOSER_NUM_PREDICT=4096
AGENT_TASK_CONTINUITY_TIMEOUT_MS=120000
AGENT_TASK_CONTINUITY_NUM_CTX=32768
AGENT_TASK_CONTINUITY_NUM_PREDICT=4096

# Supporting structured stages.
AGENT_RESPONSE_REVIEW_TIMEOUT_MS=120000
AGENT_CAPABILITY_NUM_CTX=32768
AGENT_CAPABILITY_NUM_PREDICT=4096
AGENT_CAPABILITY_REVIEW_NUM_PREDICT=4096
ROUTER_TIMEOUT_MS=120000
ROUTER_LLM_TIMEOUT_MS=120000
ROUTER_LLM_NUM_CTX=32768
ROUTER_LLM_NUM_PREDICT=4096
ROUTER_REVIEW_TIMEOUT_MS=120000

# Allow the critical cognitive request and Social Attention request to run
# concurrently. If the hardware cannot sustain this, the resulting transport or
# model-budget failure is evidence about infrastructure capacity, not cognition.
OLLAMA_NUM_PARALLEL=2
OLLAMA_MAX_LOADED_MODELS=2

# Host budgets must exceed the corresponding Agent budgets.
ORCH_GOAL_ASSOCIATION_TIMEOUT_MS=150000
ORCH_FAST_PLANNER_TIMEOUT_MS=150000
ORCH_DEEP_PLANNER_TIMEOUT_MS=150000
ORCH_RESPONSE_COMPOSER_TIMEOUT_MS=150000
ORCH_TASK_CONTINUITY_TIMEOUT_MS=150000
ORCH_COGNITIVE_RUNTIME_TIMEOUT_MS=600000
