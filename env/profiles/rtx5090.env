# RTX 5090 / Blackwell profile
CHROMIE_HARDWARE_PROFILE=rtx5090
CHROMIE_ARCH=x86_64
CHROMIE_GPU_VENDOR=nvidia
CHROMIE_GPU_CLASS=desktop

# Blackwell compute capability 12.0
TTS_CUDA_ARCH=120

ASR_MODEL=small.en
ASR_COMPUTE_TYPE=float16

# High-quality local talking brain. Use warm_ollama before orchestrator.
AGENT_MODEL=gemma4:26b
OLLAMA_MODEL=gemma4:26b
AGENT_TIMEOUT_MS=120000
ORCH_AGENT_TIMEOUT_MS=130000

OLLAMA_CONTEXT_LENGTH=4096
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_PREDICT=64
OLLAMA_TEMPERATURE=0.35
OLLAMA_TOP_P=0.9
OLLAMA_KEEP_ALIVE=24h
OLLAMA_LOAD_TIMEOUT=10m

TTS_MODEL_SIZE=0.6B
TTS_CONTEXT_SIZE=4096
TTS_MAX_LENGTH=4096
MIN_TTS_GENERATION_LENGTH=1024
TTS_MAX_TEXT_CHARS=220
TTS_N_BATCH=256
TTS_THREADS=8
