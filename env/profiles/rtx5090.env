# RTX 5090 / Blackwell profile
CHROMIE_HARDWARE_PROFILE=rtx5090
CHROMIE_ARCH=x86_64
CHROMIE_GPU_VENDOR=nvidia
CHROMIE_GPU_CLASS=desktop

# Blackwell compute capability 12.0
TTS_CUDA_ARCH=120

ASR_MODEL=/root/.cache/huggingface/sherpa-onnx/sherpa-onnx-sense-voice-zh-en-ja-ko-yue-int8-2024-07-17
ASR_MODEL_REVISION=asr-models/sherpa-onnx-sense-voice-zh-en-ja-ko-yue-int8-2024-07-17

# High-quality local talking brain. Use warm_ollama before orchestrator.
AGENT_MODEL=gemma4:26b
OLLAMA_MODEL=gemma4:26b

# Complete cognitive model plan owned by this detected hardware profile.
# Do not override these keys in .env.local; create or update a profile instead.
ROUTER_MODEL=qwen3:4b
ROUTER_REVIEW_MODEL=gemma4:26b
AGENT_GOAL_ASSOCIATION_MODEL=qwen3:4b
AGENT_FAST_PLANNER_MODEL=qwen3:4b
AGENT_DEEP_PLANNER_MODEL=gemma4:26b
AGENT_RESPONSE_COMPOSER_MODEL=gemma4:26b
AGENT_TOOL_RESULT_INTERPRETER_MODEL=gemma4:26b
AGENT_TASK_CONTINUITY_MODEL=qwen3:4b
AGENT_SOCIAL_ATTENTION_MODEL=qwen3:4b
AGENT_RESPONSE_REVIEW_MODEL=gemma4:26b

# Qualification-phase cognitive budgets.
# During architecture/workflow validation, correctness and complete model
# output take priority over response latency. Keep the Agent stage timeout at
# the contract maximum, give the host a larger envelope for HTTP/serialization
# overhead, and allow the complete staged pipeline to finish. Tune these down
# only after retained live evidence establishes warm p95/p99 latency.
CHROMIE_COGNITIVE_BUDGET_PROFILE=qualification
ROUTER_TIMEOUT_MS=120000
ROUTER_LLM_TIMEOUT_MS=120000
ROUTER_REVIEW_TIMEOUT_MS=120000
AGENT_RESPONSE_REVIEW_TIMEOUT_MS=120000
AGENT_GOAL_ASSOCIATION_TIMEOUT_MS=120000
AGENT_FAST_PLANNER_TIMEOUT_MS=120000
AGENT_DEEP_PLANNER_TIMEOUT_MS=120000
AGENT_RESPONSE_COMPOSER_TIMEOUT_MS=120000
AGENT_TOOL_RESULT_INTERPRETER_TIMEOUT_MS=120000
AGENT_TASK_CONTINUITY_TIMEOUT_MS=120000
ORCH_ROUTER_TIMEOUT_MS=150000
ORCH_GOAL_ASSOCIATION_TIMEOUT_MS=150000
ORCH_FAST_PLANNER_TIMEOUT_MS=150000
ORCH_DEEP_PLANNER_TIMEOUT_MS=150000
ORCH_RESPONSE_COMPOSER_TIMEOUT_MS=150000
ORCH_TOOL_RESULT_INTERPRETER_TIMEOUT_MS=150000
ORCH_TASK_CONTINUITY_TIMEOUT_MS=150000
ORCH_COGNITIVE_RUNTIME_TIMEOUT_MS=900000
OLLAMA_WARM_REQUEST_TIMEOUT_SECONDS=600
AGENT_TIMEOUT_MS=240000
ORCH_AGENT_TIMEOUT_MS=300000

OLLAMA_CONTEXT_LENGTH=4096
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_PREDICT=64
OLLAMA_TEMPERATURE=0.35
OLLAMA_TOP_P=0.9
OLLAMA_KEEP_ALIVE=24h
OLLAMA_LOAD_TIMEOUT=10m

TTS_MODEL_SIZE=0.6B
TTS_CONTEXT_SIZE=8192
TTS_MAX_LENGTH=8192
# Keep cloned-speaker requests and retries independent. OuteTTS 0.4.4 mutates
# prompt state internally, and voice consistency is more important than the
# small prompt-cache latency gain on this profile.
TTS_RESET_LLAMA_STATE=1
MIN_TTS_GENERATION_LENGTH=1024
TTS_MAX_TEXT_CHARS=220
TTS_N_BATCH=256
TTS_THREADS=8
TTS_WORKER_COUNT=2
TTS_MAX_CONCURRENT_SYNTHESIS=2
