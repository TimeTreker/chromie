# Jetson AGX Orin profile
CHROMIE_HARDWARE_PROFILE=jetson_agx_orin
CHROMIE_ARCH=aarch64
CHROMIE_GPU_VENDOR=nvidia
CHROMIE_GPU_CLASS=jetson
CHROMIE_JETSON=1

TTS_CUDA_ARCH=87

ROUTER_USE_LLM=0

ASR_MODEL=base.en
ASR_MODEL_REVISION=b9aa26eecb911386885c475d79736c5e76dd09bd
ASR_COMPUTE_TYPE=int8_float16
ASR_BEAM_SIZE=1

AGENT_MODEL=gemma4:e2b
OLLAMA_MODEL=gemma4:e2b
AGENT_TIMEOUT_MS=45000
ORCH_AGENT_TIMEOUT_MS=55000

OLLAMA_CONTEXT_LENGTH=2048
OLLAMA_NUM_CTX=2048
OLLAMA_NUM_PREDICT=56
OLLAMA_TEMPERATURE=0.35
OLLAMA_TOP_P=0.9
OLLAMA_KEEP_ALIVE=24h
OLLAMA_LOAD_TIMEOUT=10m
OLLAMA_NUM_PARALLEL=1

TTS_MODEL_SIZE=0.6B
TTS_CONTEXT_SIZE=2048
TTS_MAX_LENGTH=2048
MIN_TTS_GENERATION_LENGTH=1024
TTS_MAX_TEXT_CHARS=160
TTS_N_BATCH=128
TTS_THREADS=6
