# Desktop RTX 4090 profile
CHROMIE_HARDWARE_PROFILE=rtx4090
CHROMIE_ARCH=x86_64
CHROMIE_GPU_VENDOR=nvidia
CHROMIE_GPU_CLASS=desktop

# Ada Lovelace compute capability 8.9
TTS_CUDA_ARCH=89

ASR_MODEL=/root/.cache/huggingface/sherpa-onnx/sherpa-onnx-sense-voice-zh-en-ja-ko-yue-int8-2024-07-17
ASR_MODEL_REVISION=asr-models/sherpa-onnx-sense-voice-zh-en-ja-ko-yue-int8-2024-07-17

# Keep 4090 defaults responsive. Override to gemma4:26b in .env.local if desired.
AGENT_MODEL=gemma4:e2b
OLLAMA_MODEL=gemma4:e2b

# Complete cognitive model plan owned by this detected hardware profile.
# Do not override these keys in .env.local; create or update a profile instead.
ROUTER_MODEL=qwen3:4b
ROUTER_REVIEW_MODEL=gemma4:e2b
AGENT_GOAL_ASSOCIATION_MODEL=qwen3:4b
AGENT_FAST_PLANNER_MODEL=qwen3:4b
AGENT_DEEP_PLANNER_MODEL=gemma4:e2b
AGENT_RESPONSE_COMPOSER_MODEL=gemma4:e2b
AGENT_TOOL_RESULT_INTERPRETER_MODEL=gemma4:e2b
AGENT_TASK_CONTINUITY_MODEL=qwen3:4b
AGENT_SOCIAL_ATTENTION_MODEL=qwen3:4b
AGENT_RESPONSE_REVIEW_MODEL=gemma4:e2b
AGENT_TIMEOUT_MS=30000
ORCH_AGENT_TIMEOUT_MS=40000

OLLAMA_CONTEXT_LENGTH=2048
OLLAMA_NUM_CTX=2048
OLLAMA_NUM_PREDICT=64
OLLAMA_TEMPERATURE=0.35
OLLAMA_TOP_P=0.9

TTS_MODEL_SIZE=0.6B
TTS_CONTEXT_SIZE=4096
TTS_MAX_LENGTH=4096
MIN_TTS_GENERATION_LENGTH=1024
TTS_MAX_TEXT_CHARS=220
TTS_N_BATCH=192
TTS_THREADS=6
