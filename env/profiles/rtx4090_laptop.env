# RTX 4090 Laptop GPU profile (typically 16GB VRAM)
CHROMIE_HARDWARE_PROFILE=rtx4090_laptop
CHROMIE_ARCH=x86_64
CHROMIE_GPU_VENDOR=nvidia
CHROMIE_GPU_CLASS=laptop

TTS_CUDA_ARCH=89

ASR_BACKEND=sherpa_onnx
ASR_MODEL=/root/.cache/huggingface/sherpa-onnx/sherpa-onnx-sense-voice-zh-en-ja-ko-yue-int8-2024-07-17
ASR_MODEL_REVISION=asr-models/sherpa-onnx-sense-voice-zh-en-ja-ko-yue-int8-2024-07-17
ASR_COMPUTE_TYPE=int8

AGENT_MODEL=gemma4:e2b
OLLAMA_MODEL=gemma4:e2b
AGENT_TIMEOUT_MS=45000
ORCH_AGENT_TIMEOUT_MS=55000

OLLAMA_CONTEXT_LENGTH=2048
OLLAMA_NUM_CTX=2048
OLLAMA_NUM_PREDICT=56
OLLAMA_TEMPERATURE=0.35
OLLAMA_TOP_P=0.9
OLLAMA_NUM_PARALLEL=1

TTS_MODEL_SIZE=0.6B
# OuteTTS max_length includes the speaker/prompt tokens as well as generated
# audio-code tokens. 2048 can leave only enough generation headroom for the
# first words of an otherwise short sentence, so the maintained profile keeps
# the previously complete 4096-token window.
TTS_CONTEXT_SIZE=4096
TTS_MAX_LENGTH=4096
MIN_TTS_GENERATION_LENGTH=1024
TTS_MAX_TEXT_CHARS=200
TTS_N_BATCH=160
TTS_THREADS=6
