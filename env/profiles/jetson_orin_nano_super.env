# Jetson Orin Nano Super local/edge profile
# Notes:
# - This profile keeps model sizes small for 8GB shared memory.
# - ARM64/Jetson-compatible Dockerfiles/images may still be required.
CHROMIE_HARDWARE_PROFILE=jetson_orin_nano_super
CHROMIE_ARCH=aarch64
CHROMIE_GPU_VENDOR=nvidia
CHROMIE_GPU_CLASS=jetson
CHROMIE_JETSON=1

# Orin family Ampere GPU is compute capability 8.7.
TTS_CUDA_ARCH=87

ROUTER_USE_LLM=0

ASR_BACKEND=sherpa_onnx
ASR_MODEL=/root/.cache/huggingface/sherpa-onnx/sherpa-onnx-sense-voice-zh-en-ja-ko-yue-int8-2024-07-17
ASR_MODEL_REVISION=asr-models/sherpa-onnx-sense-voice-zh-en-ja-ko-yue-int8-2024-07-17
ASR_COMPUTE_TYPE=int8
ASR_BEAM_SIZE=1

# User-requested small local talking model class.
AGENT_MODEL=gemma4:e2b
OLLAMA_MODEL=gemma4:e2b

# Complete cognitive model plan owned by this detected hardware profile.
# Do not override these keys in .env.local; create or update a profile instead.
ROUTER_MODEL=qwen3:4b
ROUTER_REVIEW_MODEL=gemma4:e2b
AGENT_GOAL_ASSOCIATION_MODEL=qwen3:4b
AGENT_FAST_PLANNER_MODEL=qwen3:4b
AGENT_DEEP_PLANNER_MODEL=gemma4:e2b
AGENT_RESPONSE_COMPOSER_MODEL=gemma4:e2b
AGENT_TASK_CONTINUITY_MODEL=qwen3:4b
AGENT_SOCIAL_ATTENTION_MODEL=qwen3:4b
AGENT_RESPONSE_REVIEW_MODEL=gemma4:e2b
AGENT_TIMEOUT_MS=30000
ORCH_AGENT_TIMEOUT_MS=40000

OLLAMA_CONTEXT_LENGTH=2048
OLLAMA_NUM_CTX=2048
OLLAMA_NUM_PREDICT=40
OLLAMA_TEMPERATURE=0.35
OLLAMA_TOP_P=0.9
OLLAMA_KEEP_ALIVE=24h
OLLAMA_LOAD_TIMEOUT=10m
OLLAMA_NUM_PARALLEL=1

# OuteTTS generation budget. Do not set TTS_MAX_LENGTH to text-char limits
# such as 100/120; use TTS_MAX_TEXT_CHARS for that.
TTS_MODEL_SIZE=0.6B
TTS_CONTEXT_SIZE=2048
TTS_MAX_LENGTH=2048
MIN_TTS_GENERATION_LENGTH=1024
TTS_MAX_TEXT_CHARS=120
TTS_N_BATCH=96
TTS_THREADS=4
TTS_MAX_CONCURRENT_SYNTHESIS=1
