{
  "schema_version": 1,
  "id": "chinese_walk_after_weather_intent_repaired",
  "suite": "router",
  "level": "integration",
  "description": "The Chinese walking request observed in live logs must not inherit the previous weather intent; semantic repair must ground it to the bounded walking skill.",
  "tags": [
    "voice-log",
    "router-contract",
    "semantic-repair",
    "weather-context-pollution",
    "walk",
    "zh-CN"
  ],
  "input": {
    "text": "往前跑个十来秒，速度点。",
    "language": "zh-CN"
  },
  "stub": {
    "router_mode": "hybrid",
    "catalog": {
      "catalog_version": 73,
      "capabilities": [
        {
          "capability_id": "chromie.weather.lookup",
          "agent_id": "chromie.tool",
          "description": "Read current weather or forecast for a city.",
          "route": "tool",
          "prompt_tier": "common",
          "available": true,
          "interaction_executable": true,
          "effects": ["read_only", "weather_lookup"],
          "safety_class": "safe_read"
        },
        {
          "capability_id": "soridormi.walk_velocity",
          "agent_id": "soridormi.skill",
          "description": "Walk forward or backward at a bounded velocity for a bounded duration.",
          "route": "robot_action",
          "prompt_tier": "common",
          "available": true,
          "interaction_executable": true,
          "effects": ["physical_motion"],
          "safety_class": "physical_motion",
          "requires_confirmation": true,
          "input_schema": {
            "type": "object",
            "properties": {
              "vx_mps": {"type": "number"},
              "duration_s": {"type": "number"}
            },
            "required": ["vx_mps", "duration_s"]
          }
        }
      ]
    },
    "llm_script": [
      {
        "stage": "quick_intent",
        "decision": {
          "route": "chat",
          "intent": "weather_query",
          "confidence": 0.95,
          "language": "zh-CN",
          "metadata": {"tool_name": "weather"}
        }
      },
      {
        "stage": "semantic_route_repair",
        "decision": {
          "route": "robot_action",
          "intent": "capability:soridormi.walk_velocity",
          "confidence": 0.96,
          "language": "zh-CN",
          "actions": [
            {
              "capability_id": "soridormi.walk_velocity",
              "args": {"vx_mps": 0.25, "duration_s": 10.0},
              "sequence": 0,
              "timing": "sequential",
              "confidence": 0.96
            }
          ]
        }
      }
    ]
  },
  "expect": {
    "route": "robot_action",
    "intent": "capability:soridormi.walk_velocity",
    "source": "llm",
    "llm_calls": 2,
    "llm_stages": ["quick_intent", "semantic_route_repair"],
    "actions": [
      {
        "capability_id": "soridormi.walk_velocity",
        "args": {"vx_mps": 0.25, "duration_s": 10.0}
      }
    ],
    "task_types_include": ["task.execute_skill"],
    "task_types_forbid": ["task.use_tool", "speech.answer"],
    "metadata_json_contains": [
      "semantic_route_repair",
      "weather_semantics_require_tool_route",
      "soridormi.walk_velocity"
    ]
  }
}
