{
  "schema_version": 1,
  "id": "walk_forward_stale_weather_route_repaired",
  "suite": "router",
  "level": "integration",
  "description": "A stale high-confidence weather intent on a clear walking request must be rejected and semantically repaired to the exact walking skill.",
  "tags": [
    "voice-log",
    "router-contract",
    "semantic-repair",
    "weather-context-pollution",
    "walk"
  ],
  "input": {
    "text": "walk forward for 15 seconds quickly",
    "language": "en-US"
  },
  "stub": {
    "router_mode": "hybrid",
    "catalog": {
      "catalog_version": 70,
      "capabilities": [
        {
          "capability_id": "chromie.weather.lookup",
          "agent_id": "chromie.tool",
          "description": "Read current weather or forecast for a city.",
          "route": "tool",
          "prompt_tier": "common",
          "available": true,
          "interaction_executable": true,
          "effects": ["read_only", "weather_lookup"],
          "safety_class": "safe_read"
        },
        {
          "capability_id": "soridormi.walk_velocity",
          "agent_id": "soridormi.skill",
          "description": "Walk forward or backward at a bounded velocity for a bounded duration.",
          "route": "robot_action",
          "prompt_tier": "common",
          "available": true,
          "interaction_executable": true,
          "effects": ["physical_motion"],
          "safety_class": "physical_motion",
          "requires_confirmation": true,
          "input_schema": {
            "type": "object",
            "properties": {
              "vx_mps": {"type": "number"},
              "duration_s": {"type": "number"}
            },
            "required": ["vx_mps", "duration_s"]
          }
        }
      ]
    },
    "llm_script": [
      {
        "stage": "quick_intent",
        "decision": {
          "route": "chat",
          "intent": "weather_query",
          "confidence": 0.95,
          "language": "en-US",
          "metadata": {"tool_name": "weather"}
        }
      },
      {
        "stage": "semantic_route_repair",
        "decision": {
          "route": "robot_action",
          "intent": "capability:soridormi.walk_velocity",
          "confidence": 0.97,
          "language": "en-US",
          "actions": [
            {
              "capability_id": "soridormi.walk_velocity",
              "args": {"vx_mps": 0.25, "duration_s": 15.0},
              "sequence": 0,
              "timing": "sequential",
              "confidence": 0.97
            }
          ]
        }
      }
    ]
  },
  "expect": {
    "route": "robot_action",
    "intent": "capability:soridormi.walk_velocity",
    "source": "llm",
    "llm_calls": 2,
    "llm_stages": ["quick_intent", "semantic_route_repair"],
    "actions": [
      {
        "capability_id": "soridormi.walk_velocity",
        "args": {"vx_mps": 0.25, "duration_s": 15.0}
      }
    ],
    "task_types_include": ["task.execute_skill"],
    "metadata_json_contains": [
      "semantic_route_repair",
      "weather_semantics_require_tool_route",
      "soridormi.walk_velocity"
    ]
  }
}
