{
  "schema_version": 1,
  "id": "confirmation_denied_followup",
  "suite": "dialogue",
  "level": "integration",
  "description": "The robot keeps a physical action gated when the user denies confirmation.",
  "tags": ["real-world", "confirmation", "robot-action"],
  "turns": [
    {
      "id": "blink_request",
      "ask": "Blink twice to signal ready.",
      "stub": {
        "route_decision": {
          "route": "robot_action",
          "agents": ["capability_agent", "safety_agent", "speaker_agent"],
          "intent": "visual_signal",
          "confidence": 0.93,
          "language": "en-US",
          "source": "catalog",
          "actions": [
            {"capability_id": "soridormi.blink_eyes", "args": {"count": 2}, "sequence": 0}
          ]
        }
      },
      "expect": {
        "speech_any": ["run that action"],
        "skills": ["soridormi.blink_eyes"],
        "requires_confirmation": true
      }
    },
    {
      "id": "deny_confirmation",
      "ask": "No, do not do it.",
      "stub": {
        "route_decision": {
          "route": "chat",
          "agents": ["conversation_agent", "speaker_agent"],
          "intent": "cancel_pending_action",
          "confidence": 0.9,
          "language": "en-US",
          "source": "llm"
        },
        "ollama_reply": "Understood. I will not blink unless you make a new confirmed request."
      },
      "expect": {
        "speech_any": ["will not blink", "new confirmed request"],
        "history_contains": ["Blink twice", "run that action"],
        "no_skills": true
      }
    }
  ]
