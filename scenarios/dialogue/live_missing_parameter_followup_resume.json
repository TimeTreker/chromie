      {
        "capability_id": "soridormi.blink_eyes",
        "description": "Blink the eyes a bounded number of times.",
        "input_schema": {
          "type": "object",
          "properties": {
            "count": {"type": "integer", "minimum": 1, "maximum": 6, "description": "眨眼次数"}
          },
          "required": ["count"],
          "additionalProperties": false
