{
  "schema_version": 1,
  "id": "live_missing_parameter_followup_resume",
  "suite": "dialogue",
  "level": "integration",
  "description": "A material compound-action gap remains attached to the original task, can be explained on follow-up, and is resolved by a later duration answer without losing the blink request.",
