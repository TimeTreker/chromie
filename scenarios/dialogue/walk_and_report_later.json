{
  "schema_version": 1,
  "id": "walk_and_report_later",
  "suite": "dialogue",
  "level": "integration",
  "description": "A walk request is converted to a confirmed skill and later reported as pending.",
  "tags": ["real-world", "robot-action", "confirmation"],
  "turns": [
    {
      "id": "walk_request",
      "ask": "Please walk forward for two seconds.",
      "stub": {
        "route_decision": {
          "route": "robot_action",
          "agents": ["capability_agent", "safety_agent", "speaker_agent"],
          "intent": "compound_robot_action",
          "confidence": 0.98,
          "language": "en-US",
          "source": "catalog",
          "metadata": {
            "task_relation": "new_task",
            "task_context_patch": {
              "task_type": "robot_action",
              "goal": "Walk forward for two seconds after confirmation",
              "entities": ["forward walking"]
            }
          },
          "actions": [
            {
              "capability_id": "soridormi.walk_velocity",
              "args": {"vx_mps": 0.2, "duration_s": 2.0},
              "sequence": 0
            }
          ]
        }
      },
      "expect": {
        "speech_any": ["run that action"],
        "skills": ["soridormi.walk_velocity"],
        "requires_confirmation": true
      }
    },
    {
      "id": "later_status",
      "ask": "What are you waiting on?",
      "stub": {
        "route_decision": {
          "route": "chat",
          "agents": ["conversation_agent", "speaker_agent"],
          "intent": "task_status",
          "confidence": 0.87,
          "language": "en-US",
          "source": "llm",
          "metadata": {"task_relation": "continue_task"}
        },
        "ollama_reply": "I am waiting for confirmation before walking forward."
      },
      "expect": {
        "speech_any": ["waiting for confirmation", "walking forward"],
        "history_contains": ["walk forward for two seconds"],
        "session_memory_contains": ["Walk forward for two seconds", "soridormi.walk_velocity"],
        "no_skills": true
      }
    }
  ]
}
