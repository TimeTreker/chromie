{
  "schema_version": 1,
  "id": "walk_then_followup_status",
  "suite": "dialogue",
  "level": "integration",
  "description": "A follow-up turn can see the prior walking request and pending task context.",
  "tags": ["multi-turn", "robot-action", "task-context"],
  "turns": [
    {
      "id": "walk_request",
      "ask": "Walk forward slowly.",
      "stub": {
        "route_decision": {
          "route": "robot_action",
          "agents": ["capability_agent", "safety_agent", "speaker_agent"],
          "intent": "compound_robot_action",
          "confidence": 0.99,
          "language": "en-US",
          "source": "catalog",
          "metadata": {
            "task_relation": "new_task",
            "task_context_patch": {
              "task_type": "robot_action",
              "goal": "Walk forward slowly after confirmation",
              "entities": ["forward walking"],
              "constraints": {
                "speed": "slow"
              }
            }
          },
          "actions": [
            {
              "capability_id": "soridormi.walk_velocity",
              "args": {
                "vx_mps": 0.15,
                "duration_s": 2.0
              },
              "sequence": 0
            }
          ]
        }
      },
      "expect": {
        "speech_any": ["run that action"],
        "skills": ["soridormi.walk_velocity"],
        "requires_confirmation": true,
        "post_history_contains": ["Walk forward slowly.", "run that action"],
        "current_task_context_contains": ["Walk forward slowly after confirmation", "forward walking"]
      }
    },
    {
      "id": "followup_status",
      "ask": "Did you do that?",
      "stub": {
        "route_decision": {
          "route": "chat",
          "agents": ["conversation_agent", "speaker_agent"],
          "intent": "general_conversation",
          "confidence": 0.86,
          "language": "en-US",
          "source": "llm",
          "metadata": {
            "task_relation": "continue_task"
          }
        },
        "ollama_reply": "I am still waiting for confirmation before moving."
      },
      "expect": {
        "speech_any": ["waiting for confirmation"],
        "no_skills": true,
        "history_contains": ["Walk forward slowly.", "run that action"],
        "session_memory_contains": ["Walk forward slowly after confirmation", "soridormi.walk_velocity"],
        "current_task_context_contains": ["Walk forward slowly after confirmation"]
      }
    }
  ]
}
