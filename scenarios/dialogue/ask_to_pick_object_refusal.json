        "no_skills": true
      }
    },
    {
      "id": "ask_alternative",
      "ask": "What should happen instead?",
      "stub": {
        "route_decision": {
          "route": "chat",
          "agents": ["conversation_agent", "speaker_agent"],
          "intent": "safe_alternative",
          "confidence": 0.85,
          "language": "en-US",
          "source": "llm"
        },
        "ollama_reply": "A person should pick it up carefully or use a proper tool, then place it somewhere safe."
      },
      "expect": {
        "speech_any": ["person should pick it up", "somewhere safe"],
        "history_contains": ["approved object pickup skill"],
        "no_skills": true
      }
    }
