{
  "schema_version": 1,
  "id": "chinese_walk_then_status",
  "suite": "dialogue",
  "level": "integration",
  "description": "A Chinese walking request maps to the same safe action contract.",
  "tags": ["real-world", "zh-CN", "robot-action"],
  "turns": [
    {
      "id": "walk_request",
      "ask": "请慢慢向前走一步。",
      "stub": {
        "route_decision": {
          "route": "robot_action",
          "agents": ["capability_agent", "safety_agent", "speaker_agent"],
          "intent": "compound_robot_action",
          "confidence": 0.95,
          "language": "zh-CN",
          "source": "catalog",
          "metadata": {
            "task_relation": "new_task",
            "task_context_patch": {
              "task_type": "robot_action",
              "goal": "慢慢向前走一步，等待确认",
              "entities": ["向前", "慢慢"]
            }
          },
          "actions": [
            {
              "capability_id": "soridormi.walk_velocity",
              "args": {"vx_mps": 0.12, "duration_s": 1.2},
              "sequence": 0
            }
          ]
        }
      },
      "expect": {
        "speech_any": ["执行这个动作"],
        "skills": ["soridormi.walk_velocity"],
        "requires_confirmation": true,
        "current_task_context_contains": ["向前", "慢慢"]
      }
    },
    {
      "id": "status",
      "ask": "你现在要做什么？",
      "stub": {
        "route_decision": {
          "route": "chat",
          "agents": ["conversation_agent", "speaker_agent"],
          "intent": "task_status",
          "confidence": 0.87,
          "language": "zh-CN",
          "source": "llm",
          "metadata": {"task_relation": "continue_task"}
        },
        "ollama_reply": "我在等待确认，然后才会慢慢向前走一步。"
      },
      "expect": {
        "speech_any": ["等待确认", "向前走一步"],
        "session_memory_contains": ["soridormi.walk_velocity", "向前"],
        "no_skills": true
      }
    }
  ]
}
