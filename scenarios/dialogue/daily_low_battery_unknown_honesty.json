{
  "schema_version": 1,
  "id": "daily_low_battery_unknown_honesty",
  "suite": "dialogue",
  "level": "integration",
  "description": "The robot does not claim a battery level when no verified status is present.",
  "tags": ["daily-life", "status-boundary", "honesty"],
  "turns": [
    {
      "id": "ask_battery",
      "ask": "Are you low on battery right now?",
      "stub": {
        "route_decision": {
          "route": "chat",
          "agents": ["conversation_agent", "speaker_agent"],
          "intent": "status_boundary",
          "confidence": 0.87,
          "language": "en-US",
          "source": "llm"
        },
        "ollama_reply": "I do not have a verified battery reading in this context, so I should not invent one."
      },
      "expect": {
        "speech_any": ["verified battery reading", "should not invent"],
        "no_skills": true
      }
    },
    {
      "id": "ask_next",
      "ask": "What can you say instead?",
      "stub": {
        "route_decision": {
          "route": "chat",
          "agents": ["conversation_agent", "speaker_agent"],
          "intent": "status_safe_alternative",
          "confidence": 0.84,
          "language": "en-US",
          "source": "llm"
        },
        "ollama_reply": "I can report battery status only when a trusted status source provides it."
      },
      "expect": {
        "speech_any": ["trusted status source"],
        "history_contains": ["verified battery reading"],
        "no_skills": true
      }
    }
  ]
}
