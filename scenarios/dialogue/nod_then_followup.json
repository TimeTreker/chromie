{
  "schema_version": 1,
  "id": "nod_then_followup",
  "suite": "dialogue",
  "level": "integration",
  "description": "A visible nod request uses the nod skill and remains understandable in a follow-up.",
  "tags": ["real-world", "robot-action", "gesture"],
  "turns": [
    {
      "id": "nod_request",
      "ask": "Can you nod if you understood?",
      "stub": {
        "route_decision": {
          "route": "robot_action",
          "agents": ["capability_agent", "safety_agent", "speaker_agent"],
          "intent": "gesture_confirmation",
          "confidence": 0.93,
          "language": "en-US",
          "source": "catalog",
          "metadata": {
            "task_relation": "new_task",
            "task_context_patch": {
              "task_type": "robot_action",
              "goal": "Nod yes to show understanding",
              "entities": ["nod yes"]
            }
          },
          "actions": [
            {"capability_id": "soridormi.nod_yes", "args": {}, "sequence": 0}
          ]
        }
      },
      "expect": {
        "speech_any": ["run that action"],
        "skills": ["soridormi.nod_yes"],
        "requires_confirmation": true
      }
    },
    {
      "id": "ask_meaning",
      "ask": "What was that nod for?",
      "stub": {
        "route_decision": {
          "route": "chat",
          "agents": ["conversation_agent", "speaker_agent"],
          "intent": "explain_prior_action",
          "confidence": 0.87,
          "language": "en-US",
          "source": "llm",
          "metadata": {"task_relation": "continue_task"}
        },
        "ollama_reply": "It was meant to show that I understood you, pending confirmation."
      },
      "expect": {
        "speech_any": ["understood", "pending confirmation"],
        "history_contains": ["nod if you understood"],
        "session_memory_contains": ["Nod yes", "soridormi.nod_yes"],
        "no_skills": true
      }
    }
  ]
}
