      "ask": "For later, I usually like jasmine tea without sugar.",
      "stub": {
        "route_decision": {
          "route": "chat",
          "agents": ["conversation_agent", "speaker_agent"],
          "intent": "remember_preference",
          "confidence": 0.91,
          "language": "en-US",
