{
  "schema_version": "0.1",
  "source": "soridormi",
  "agents": [
    {
      "agent_id": "soridormi.robot",
      "display_name": "Soridormi Robot",
      "description": "Safety-scoped robot status, planning, motion, and emergency controls.",
      "version": "0.1.0",
      "transport": {
        "kind": "mcp_streamable_http",
        "url": "${SORIDORMI_MCP_URL}"
      },
      "tags": [
        "robot",
        "mcp",
        "physical"
      ],
      "tools": [
        {
          "name": "soridormi.robot.get_status",
          "agent_id": "soridormi.robot",
          "description": "Read the robot mode, pose summary, battery, and active safety state.",
          "input_schema": {
            "type": "object",
            "properties": {}
          },
          "output_schema": {
            "type": "object"
          },
          "effects": [
            "read_only"
          ],
          "safety_class": "safe_read",
          "execution": {
            "timeout_s": 5,
            "side_effect_free": true,
            "idempotent": true
          }
        },
        {
          "name": "soridormi.motion.create_plan",
          "agent_id": "soridormi.robot",
          "description": "Create a bounded robot motion plan without moving hardware.",
          "input_schema": {
            "type": "object",
            "properties": {
              "commands": {
                "type": "array",
                "minItems": 1,
                "maxItems": 20,
                "items": {
                  "type": "object",
                  "properties": {
                    "vx": {
                      "type": "number",
                      "minimum": -0.2,
                      "maximum": 0.2
                    },
                    "vy": {
                      "type": "number",
                      "minimum": -0.1,
                      "maximum": 0.1
                    },
                    "yaw": {
                      "type": "number",
                      "minimum": -0.4,
                      "maximum": 0.4
                    },
                    "duration_s": {
                      "type": "number",
                      "minimum": 0.05,
                      "maximum": 5
                    }
                  },
                  "required": [
                    "vx",
                    "vy",
                    "yaw",
                    "duration_s"
                  ]
                }
              }
            },
            "required": [
              "commands"
            ]
          },
          "output_schema": {
            "type": "object",
            "properties": {
              "plan_id": {
                "type": "string"
              },
              "summary": {
                "type": "string"
              }
            },
            "required": [
              "plan_id",
              "summary"
            ]
          },
          "effects": [
            "planning_only",
            "creates_plan"
          ],
          "safety_class": "planning_only",
          "execution": {
            "timeout_s": 10,
            "side_effect_free": true,
            "idempotent": true
          }
        },
        {
          "name": "soridormi.safety.monitor_motion",
          "agent_id": "soridormi.robot",
          "description": "Activate and report the safety monitor covering a motion execution.",
          "input_schema": {
            "type": "object",
            "properties": {}
          },
          "output_schema": {
            "type": "object",
            "properties": {
              "active": {
                "type": "boolean"
              }
            },
            "required": [
              "active"
            ]
          },
          "effects": [
            "read_only",
            "safety_control"
          ],
          "safety_class": "safety_critical",
          "execution": {
            "timeout_s": 5,
            "side_effect_free": true,
            "idempotent": true
          }
        },
        {
          "name": "soridormi.motion.execute_plan",
          "agent_id": "soridormi.robot",
          "description": "Execute a previously validated bounded motion plan.",
          "input_schema": {
            "type": "object",
            "properties": {
              "plan_id": {
                "type": "string"
              }
            },
            "required": [
              "plan_id"
            ]
          },
          "output_schema": {
            "type": "object",
            "properties": {
              "completed": {
                "type": "boolean"
              },
              "summary": {
                "type": "string"
              }
            },
            "required": [
              "completed"
            ]
          },
          "effects": [
            "physical_motion"
          ],
          "safety_class": "physical_motion",
          "execution": {
            "can_run_parallel": false,
            "exclusive_group": "robot_motion",
            "timeout_s": 30,
            "idempotent": false,
            "side_effect_free": false
          },
          "confirmation": {
            "required": true,
            "reason": "The plan moves physical hardware."
          },
          "monitoring": {
            "requires_safety_monitor": true,
            "recommended_monitor_tools": [
              "soridormi.safety.monitor_motion"
            ],
            "hard_interrupt_events": [
              "obstacle",
              "fall_detected",
              "emergency_stop"
            ]
          },
          "default_failure_policy": {
            "strategy": "emergency_stop"
          }
        },
        {
          "name": "soridormi.safety.emergency_stop",
          "agent_id": "soridormi.robot",
          "description": "Immediately request the robot safety layer to stop physical motion.",
          "llm_visible": false,
          "input_schema": {
            "type": "object",
            "properties": {
              "reason": {
                "type": "string"
              }
            }
          },
          "output_schema": {
            "type": "object",
            "properties": {
              "stopped": {
                "type": "boolean"
              }
            },
            "required": [
              "stopped"
            ]
          },
          "effects": [
            "safety_control"
          ],
          "safety_class": "safety_critical",
          "execution": {
            "can_run_parallel": false,
            "exclusive_group": "robot_motion",
            "timeout_s": 5,
            "idempotent": true,
            "side_effect_free": false
          }
        }
      ]
    }
  ]
}
